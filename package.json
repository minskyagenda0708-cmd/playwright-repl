{
  "name": "playwright-repl",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "build": "tsc --build packages/core/tsconfig.build.json packages/cli/tsconfig.build.json packages/mcp/tsconfig.build.json && pnpm --filter @playwright-repl/extension run build",
    "test": "pnpm run --recursive --if-present test",
    "test:core": "pnpm --filter @playwright-repl/core run test",
    "test:cli": "pnpm --filter playwright-repl run test"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
