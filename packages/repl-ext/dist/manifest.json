{
  "name": "Playwright REPL",
  "version": "0.1.0",
  "manifest_version": 3,
  "description": "Interactive REPL for Playwright browser automation",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Playwright REPL"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "permissions": ["debugger", "tabs", "activeTab", "sidePanel"]
}
