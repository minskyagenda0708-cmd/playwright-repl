{
  "manifest_version": 3,
  "name": "Playwright REPL",
  "version": "0.10.0",
  "description": "A side panel for Playwright-style browser automation commands.",
  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel",
    "debugger",
    "storage",
    "windows",
    "offscreen"
  ],
  "options_ui": {
    "page": "preferences/preferences.html",
    "open_in_tab": false
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Playwright REPL",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "panel/panel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
