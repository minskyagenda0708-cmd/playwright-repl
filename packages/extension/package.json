{
  "name": "@playwright-repl/extension",
  "version": "0.15.1",
  "private": true,
  "description": "Chrome DevTools panel extension for Playwright REPL",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:coverage": "vitest run --coverage",
    "test:component": "vitest run --config vitest.component.config.ts",
    "test:component:watch": "vitest --config vitest.component.config.ts",
    "test:component:ui": "vitest --config vitest.component.config.ts --browser.headless=false --ui --api.port 9527",
    "lint": "eslint .",
    "coverage:merge": "nextcov merge coverage/unit coverage/component coverage/e2e -o coverage/merged",
    "coverage:all": "vitest run && vitest run --config vitest.component.config.ts && npx playwright test && nextcov merge coverage/unit coverage/component coverage/e2e -o coverage/merged"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.59.0-alpha-2026-02-21",
    "@tailwindcss/vite": "^4.2.0",
    "@types/chrome": "^0.0.304",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.0.1",
    "happy-dom": "^20.6.1",
    "nextcov": "^1.2.0",
    "playwright": "1.59.0-alpha-2026-02-21",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.0.5",
    "vitest-chrome": "^0.1.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@lezer/highlight": "^1.2.3",
    "@playwright-repl/playwright-crx": "0.15.1",
    "codemirror": "^6.0.2",
    "js-yaml": "^4.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "browserslist": [
    "chrome 111",
    "edge 111",
    "firefox 111",
    "safari 16.4"
  ]
}
