    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.1",
    "happy-dom": "^20.6.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.1.0",
    "vitest": "^4.0.18",
    "vitest-chrome": "^0.1.0"
  }
