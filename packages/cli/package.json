{
  "name": "playwright-repl",
  "version": "0.6.0",
  "description": "Interactive REPL for Playwright browser automation — keyword-driven testing from your terminal",
  "type": "module",
  "bin": {
    "playwright-repl": "./dist/playwright-repl.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:e2e": "node dist/playwright-repl.js --replay examples/ --silent"
  },
  "keywords": [
    "playwright",
    "repl",
    "browser",
    "automation",
    "testing",
    "mcp",
    "keyword-driven"
  ],
  "author": "Steve Zhang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevez/playwright-repl.git"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@playwright-repl/core": "file:../core",
    "playwright": ">=1.59.0-alpha-2026-02-01"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
