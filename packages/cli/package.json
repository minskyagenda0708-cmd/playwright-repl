{
  "name": "playwright-repl",
  "version": "0.4.0",
  "description": "Interactive REPL for Playwright browser automation — keyword-driven testing from your terminal",
  "type": "module",
  "bin": {
    "playwright-repl": "./bin/playwright-repl.mjs"
  },
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "scripts": {
    "test": "vitest run"
  },
  "keywords": [
    "playwright",
    "repl",
    "browser",
    "automation",
    "testing",
    "mcp",
    "keyword-driven"
  ],
  "author": "Steve Zhang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevez/playwright-repl.git"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@playwright-repl/core": "file:../core",
    "playwright": ">=1.59.0-alpha-2026-02-01"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
