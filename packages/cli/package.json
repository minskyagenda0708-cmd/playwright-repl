{
  "name": "playwright-repl",
  "version": "0.21.9",
  "description": "Interactive REPL for Playwright — keyword commands, recording, and replay",
  "type": "module",
  "bin": {
    "playwright-repl": "./dist/playwright-repl.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:e2e": "node dist/playwright-repl.js --replay examples/ --silent",
    "test:e2e:bridge": "node e2e/test-bridge-replay.js"
  },
  "keywords": [
    "playwright",
    "repl",
    "browser",
    "automation",
    "testing",
    "mcp",
    "keyword-driven"
  ],
  "author": "Steve Zhang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevez/playwright-repl.git"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@playwright-repl/core": "workspace:*",
    "playwright": "^1.59.1",
    "playwright-core": "^1.59.1"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
