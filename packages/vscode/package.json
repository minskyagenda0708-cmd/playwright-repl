{
  "name": "@playwright-repl/vscode",
  "displayName": "Playwright REPL",
  "description": "Playwright REPL — fast test execution with live REPL, trace viewer, and bridge mode",
  "icon": "images/playwright-logo.png",
  "version": "0.20.0",
  "private": true,
  "publisher": "playwright-repl",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Testing"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "workspaceContains:**/*playwright*.config.{ts,js,mjs}"
  ],
  "contributes": {
    "commands": [
      {
        "category": "Test",
        "command": "playwright-repl.install",
        "title": "%contributes.command.playwright-repl.install%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.installBrowsers",
        "title": "%contributes.command.playwright-repl.installBrowsers%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.closeBrowsers",
        "title": "%contributes.command.playwright-repl.closeBrowsers%"
      },
      {
        "category": "Test",
        "icon": "$(gear)",
        "command": "playwright-repl.toggleModels",
        "title": "%contributes.command.playwright-repl.toggleModels%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.toggle.reuseBrowser",
        "title": "%contributes.command.playwright-repl.toggle.reuseBrowser%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.toggle.showTrace",
        "title": "%contributes.command.playwright-repl.toggle.showTrace%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.toggle.runGlobalSetupOnEachRun",
        "title": "%contributes.command.playwright-repl.toggle.runGlobalSetupOnEachRun%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.toggle.pickLocatorCopyToClipboard",
        "title": "%contributes.command.playwright-repl.toggle.pickLocatorCopyToClipboard%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.runGlobalSetup",
        "title": "%contributes.command.playwright-repl.runGlobalSetup%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.runGlobalTeardown",
        "title": "%contributes.command.playwright-repl.runGlobalTeardown%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.startDevServer",
        "title": "%contributes.command.playwright-repl.startDevServer%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.stopDevServer",
        "title": "%contributes.command.playwright-repl.stopDevServer%"
      },
      {
        "category": "Test",
        "command": "playwright-repl.clearCache",
        "title": "%contributes.command.playwright-repl.clearCache%"
      },
      {
        "category": "Playwright REPL",
        "command": "playwright-repl.launchBrowser",
        "title": "Launch Browser"
      },
      {
        "category": "Playwright REPL",
        "command": "playwright-repl.stopBrowser",
        "title": "Stop Browser"
      },
      {
        "category": "Playwright REPL",
        "command": "playwright-repl.openRepl",
        "title": "Open REPL"
      },
      {
        "category": "Playwright REPL",
        "command": "playwright-repl.startRecording",
        "icon": "$(record)",
        "title": "Start Recording"
      },
      {
        "category": "Playwright REPL",
        "command": "playwright-repl.stopRecording",
        "title": "Stop Recording"
      },
      {
        "category": "Playwright REPL",
        "command": "playwright-repl.pickLocator",
        "title": "Pick Locator"
      }
    ],
    "configuration": {
      "title": "Playwright REPL",
      "properties": {
        "playwright-repl.env": {
          "type": "object",
          "default": {},
          "description": "%configuration.playwright-repl.env%"
        },
        "playwright-repl.reuseBrowser": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.playwright-repl.reuseBrowser%"
        },
        "playwright-repl.showTrace": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.playwright-repl.showTrace%"
        },
        "playwright-repl.runGlobalSetupOnEachRun": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.playwright-repl.runGlobalSetupOnEachRun%"
        },
        "playwright-repl.pickLocatorCopyToClipboard": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.playwright-repl.pickLocatorCopyToClipboard%"
        },
        "playwright-repl.updateSnapshots": {
          "type": "string",
          "enum": ["all", "changed", "missing", "none"],
          "default": "missing",
          "description": "%configuration.playwright-repl.updateSnapshots%"
        },
        "playwright-repl.updateSourceMethod": {
          "type": "string",
          "enum": ["overwrite", "patch", "3way"],
          "default": "3way",
          "description": "%configuration.playwright-repl.updateSourceMethod%"
        },
        "playwright-repl.headless": {
          "type": "boolean",
          "default": false,
          "description": "Run browser in headless mode (no visible window)"
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "replContainer",
          "title": "REPL",
          "icon": "images/playwright-logo.png"
        },
        {
          "id": "locatorContainer",
          "title": "Locator",
          "icon": "images/playwright-logo.png"
        }
      ]
    },
    "views": {
      "test": [
        {
          "type": "webview",
          "id": "playwright-repl.settingsView",
          "name": "%views.test.playwright-repl.settingsView%"
        }
      ],
      "replContainer": [
        {
          "type": "webview",
          "id": "playwright-repl.replView",
          "name": "REPL"
        }
      ],
      "locatorContainer": [
        {
          "type": "webview",
          "id": "playwright-repl.locatorsView",
          "name": "%views.test.playwright-repl.locatorsView%"
        }
      ]
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch"
  },
  "dependencies": {
    "@babel/core": "^7.23.2",
    "@babel/helper-plugin-utils": "^7.22.5",
    "@babel/plugin-proposal-decorators": "^7.24.7",
    "@babel/preset-typescript": "^7.23.2",
    "@babel/traverse": "^7.23.2",
    "@playwright-repl/core": "workspace:*",
    "@playwright-repl/runner": "workspace:*",
    "stack-utils": "^2.0.6",
    "which": "^4.0.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.3",
    "@types/babel__helper-plugin-utils": "^7.10.2",
    "@types/babel__traverse": "^7.20.3",
    "@types/node": "^18.11.9",
    "@types/stack-utils": "^2.0.1",
    "@types/vscode": "1.93.0",
    "@types/which": "^3.0.3",
    "@types/ws": "^8.5.3",
    "esbuild": "^0.25.0"
  }
}
