{
  "name": "playwright-ide",
  "displayName": "Playwright IDE",
  "description": "Playwright IDE — fast test execution with live REPL, trace viewer, and bridge mode",
  "icon": "images/playwright-logo.png",
  "version": "0.20.0",
  "private": true,
  "publisher": "playwright-repl",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Testing"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "workspaceContains:**/*playwright*.config.{ts,js,mjs}"
  ],
  "contributes": {
    "commands": [
      {
        "category": "Test",
        "command": "playwright-ide.install",
        "title": "%contributes.command.playwright-ide.install%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.installBrowsers",
        "title": "%contributes.command.playwright-ide.installBrowsers%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.closeBrowsers",
        "title": "%contributes.command.playwright-ide.closeBrowsers%"
      },
      {
        "category": "Test",
        "icon": "$(gear)",
        "command": "playwright-ide.toggleModels",
        "title": "%contributes.command.playwright-ide.toggleModels%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.toggle.reuseBrowser",
        "title": "%contributes.command.playwright-ide.toggle.reuseBrowser%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.toggle.showTrace",
        "title": "%contributes.command.playwright-ide.toggle.showTrace%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.toggle.runGlobalSetupOnEachRun",
        "title": "%contributes.command.playwright-ide.toggle.runGlobalSetupOnEachRun%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.toggle.pickLocatorCopyToClipboard",
        "title": "%contributes.command.playwright-ide.toggle.pickLocatorCopyToClipboard%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.runGlobalSetup",
        "title": "%contributes.command.playwright-ide.runGlobalSetup%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.runGlobalTeardown",
        "title": "%contributes.command.playwright-ide.runGlobalTeardown%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.startDevServer",
        "title": "%contributes.command.playwright-ide.startDevServer%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.stopDevServer",
        "title": "%contributes.command.playwright-ide.stopDevServer%"
      },
      {
        "category": "Test",
        "command": "playwright-ide.clearCache",
        "title": "%contributes.command.playwright-ide.clearCache%"
      },
      {
        "category": "Playwright IDE",
        "command": "playwright-ide.launchBrowser",
        "title": "Playwright IDE: Launch Browser"
      },
      {
        "category": "Playwright IDE",
        "command": "playwright-ide.stopBrowser",
        "title": "Playwright IDE: Stop Browser"
      },
      {
        "category": "Playwright IDE",
        "command": "playwright-ide.openRepl",
        "title": "Playwright IDE: Open REPL"
      },
      {
        "category": "Playwright IDE",
        "command": "playwright-ide.startRecording",
        "icon": "$(record)",
        "title": "Playwright IDE: Start Recording"
      },
      {
        "category": "Playwright IDE",
        "command": "playwright-ide.stopRecording",
        "title": "Playwright IDE: Stop Recording"
      },
      {
        "category": "Playwright IDE",
        "command": "playwright-ide.pickLocator",
        "title": "Playwright IDE: Pick Locator"
      }
    ],
    "configuration": {
      "title": "Playwright IDE",
      "properties": {
        "playwright-ide.env": {
          "type": "object",
          "default": {},
          "description": "%configuration.playwright-ide.env%"
        },
        "playwright-ide.reuseBrowser": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.playwright-ide.reuseBrowser%"
        },
        "playwright-ide.showTrace": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.playwright-ide.showTrace%"
        },
        "playwright-ide.runGlobalSetupOnEachRun": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.playwright-ide.runGlobalSetupOnEachRun%"
        },
        "playwright-ide.pickLocatorCopyToClipboard": {
          "type": "boolean",
          "default": false,
          "description": "%configuration.playwright-ide.pickLocatorCopyToClipboard%"
        },
        "playwright-ide.updateSnapshots": {
          "type": "string",
          "enum": ["all", "changed", "missing", "none"],
          "default": "missing",
          "description": "%configuration.playwright-ide.updateSnapshots%"
        },
        "playwright-ide.updateSourceMethod": {
          "type": "string",
          "enum": ["overwrite", "patch", "3way"],
          "default": "3way",
          "description": "%configuration.playwright-ide.updateSourceMethod%"
        },
        "playwright-ide.headless": {
          "type": "boolean",
          "default": false,
          "description": "Run browser in headless mode (no visible window)"
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "playwrightIdeContainer",
          "title": "Playwright IDE",
          "icon": "images/playwright-logo.png"
        }
      ]
    },
    "views": {
      "test": [
        {
          "type": "webview",
          "id": "playwright-ide.settingsView",
          "name": "%views.test.playwright-ide.settingsView%"
        }
      ],
      "playwrightIdeContainer": [
        {
          "type": "webview",
          "id": "playwright-ide.locatorsView",
          "name": "%views.test.playwright-ide.locatorsView%"
        }
      ]
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch"
  },
  "dependencies": {
    "@babel/core": "^7.23.2",
    "@babel/helper-plugin-utils": "^7.22.5",
    "@babel/plugin-proposal-decorators": "^7.24.7",
    "@babel/preset-typescript": "^7.23.2",
    "@babel/traverse": "^7.23.2",
    "@playwright-repl/core": "workspace:*",
    "@playwright-repl/runner": "workspace:*",
    "stack-utils": "^2.0.6",
    "which": "^4.0.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.3",
    "@types/babel__helper-plugin-utils": "^7.10.2",
    "@types/babel__traverse": "^7.20.3",
    "@types/node": "^18.11.9",
    "@types/stack-utils": "^2.0.1",
    "@types/vscode": "1.93.0",
    "@types/which": "^3.0.3",
    "@types/ws": "^8.5.3",
    "esbuild": "^0.25.0"
  }
}
