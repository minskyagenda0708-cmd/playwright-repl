{
  "name": "@playwright-repl/runner",
  "version": "0.24.1",
  "description": "Playwright test utilities — bridge-mode compilation, node detection, and CLI subcommands",
  "type": "module",
  "bin": {
    "pw": "./dist/pw-cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./dist/bridge-utils.cjs": "./dist/bridge-utils.cjs",
    "./dist/cdpPreload.cjs": "./dist/cdpPreload.cjs"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "test": "vitest run",
    "test:e2e": "node dist/pw-cli.js test",
    "test:benchmark": "echo '--- Standard Playwright ---' && npx playwright test --workers=1 && echo '--- pw ---' && node dist/pw-cli.js test"
  },
  "dependencies": {
    "@playwright-repl/browser-extension": "workspace:*",
    "@playwright-repl/core": "workspace:*",
    "acorn": "^8.16.0",
    "acorn-walk": "^8.3.5",
    "esbuild-wasm": "^0.27.4",
    "magic-string": "^0.30.21"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.57.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "^5.0.0"
  }
}
